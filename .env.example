###############################################
# Environment
###############################################
ENV=dev                                        # "dev" or "prod" - controls cookie security, auth behavior
DATA_BACKEND=postgres                          # "postgres" (default) or "airtable" (legacy)
INTEGRATION_ENGINE=n8n                         # "n8n" (default) or "none" to skip external checks

###############################################
# Database (Postgres)
###############################################
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://fgc:${POSTGRES_PASSWORD}@postgres:5432/fgc_checkin
# Dev note: postgres is exposed on host port 5434 (container 5432)

###############################################
# Start.gg API
###############################################
STARTGG_API_KEY=your_startgg_api_token_here    # Start.gg API token (code also checks STARTGG_TOKEN)
STARTGG_CLIENT_ID=                             # Start.gg developer app client ID (OAuth admin login)
STARTGG_CLIENT_SECRET=                         # Start.gg developer app client secret
STARTGG_REDIRECT_URI=                          # OAuth callback URL
                                               # Dev:  http://localhost:8088/admin/auth/callback
                                               # Prod: https://admin.fgctrollhattan.se/auth/callback

###############################################
# n8n Integration Engine
###############################################
N8N_WEBHOOK_TOKEN=CHANGE_ME                    # Shared secret for n8n webhook calls (optional but recommended)
N8N_BASIC_AUTH_USER=admin                      # n8n basic auth user (backend uses this to call n8n)
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME              # n8n basic auth password
# N8N_INTERNAL_URL=http://n8n:5678            # Backend -> n8n URL (default: http://n8n:5678)

###############################################
# Authentication & Security
###############################################
SSE_TOKEN=CHANGE_ME                            # Token for SSE stream authentication (dashboard -> backend)
ADMIN_AUTH_COOKIE_TOKEN=CHANGE_ME              # Admin auth cookie token for dashboard/SSE access
# OAUTH_ADMIN_KEY=supersecret                  # Simple protection for OAuth admin endpoints (default: supersecret)

###############################################
# Feature Flags (uncomment to override defaults)
###############################################
# CANONICAL_PLAYER_ID_ENABLED=true             # Enable player_uuid canonical ID system (default: true)
# EBAS_REGISTER_TIMEOUT_SECONDS=75             # Timeout for eBas registration calls (default: 75)
# DEV_TOOLS_ALLOWED_IDENTITIES=viktor molina,logisticuz  # Dashboard owner allowlist for Dev tools (case-insensitive)

###############################################
# Airtable (legacy - only if DATA_BACKEND=airtable)
###############################################
# AIRTABLE_API_KEY=your_airtable_api_key_here
# AIRTABLE_BASE_ID=your_airtable_base_id_here

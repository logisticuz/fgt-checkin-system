###############################################
# 🔑 API Keys & Tokens
###############################################
AIRTABLE_API_KEY=YOUR_AIRTABLE_API_KEY_HERE
AIRTABLE_BASE_ID=YOUR_AIRTABLE_BASE_ID_HERE
N8N_WEBHOOK_TOKEN=CHANGE_ME                # optional shared secret for /n8n/webhook/* (frontend adds ?token=)
ADMIN_AUTH_COOKIE_TOKEN=CHANGE_ME          # admin auth cookie token for SSE/dashboard access

###############################################
# 🔐 Basic Authentication (n8n)
###############################################
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME            # ← set a strong password
N8N_USER_MANAGEMENT_DISABLED=true

###############################################
# 🖥️ Host
###############################################
N8N_HOST=0.0.0.0

###############################################
# 🕒 Timezone
###############################################
TZ=Europe/Stockholm

###############################################
# 🔐 Start.gg OAuth (Admin Login)
###############################################
STARTGG_CLIENT_ID=                          # Start.gg developer app client ID
STARTGG_CLIENT_SECRET=                      # Start.gg developer app client secret
STARTGG_REDIRECT_URI=                       # OAuth callback URL (set when testing via HTTPS tunnel or prod)
                                             # Prod: https://admin.fgctrollhattan.se/auth/callback

###############################################
# 🗄️ Database (Postgres)
###############################################
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://fgc:${POSTGRES_PASSWORD}@postgres:5432/fgc_checkin

###############################################
# 🌐 Environment
###############################################
ENV=dev                                     # "dev" or "prod" - controls cookie security settings
DATA_BACKEND=airtable                       # "airtable" or "postgres"
